---
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
  { href: "/stuff", label: "stuff", meta: "films / projects / experiments", color: "var(--blue)" },
  { href: "/photos", label: "photos", meta: "people / places / weddings", color: "var(--red)" },
  { href: "/under-construction", label: "things", meta: "restored / available / collected", color: "var(--green)" },
  { href: "/under-construction", label: "fine arts", meta: "paintings / drawings / illustrations", color: "var(--lavender)" },
  { href: "/under-construction", label: "writing", meta: "notes / thoughts / media", color: "var(--brown)" },
  { href: "/archive", label: "archive", meta: "personal / media / things i like", color: "var(--blue)" },
  { href: "/play", label: "play", meta: "experiments / weird little things", color: "var(--yellow)" },
  { href: "/under-construction", label: "about", meta: "who i am / what this is", color: "var(--text)" },
  { href: "/under-construction", label: "contact", meta: "inquiries / bookings / hello", color: "var(--brown)" }
];

const floatingBits = [
  { text: "✦", top: "7%", left: "6%", color: "var(--red)", size: "1rem", rotate: "-12deg" },
  { text: "◌", top: "10%", right: "9%", color: "var(--text)", size: "0.95rem", rotate: "9deg" },
  { text: "⌂", top: "21%", right: "14%", color: "var(--green)", size: "1rem", rotate: "0deg" },
  { text: "⌁", top: "58%", left: "4%", color: "var(--brown)", size: "1rem", rotate: "8deg" },
  { text: "◢", top: "74%", right: "11%", color: "var(--red)", size: "0.9rem", rotate: "-10deg" }
];
---

<BaseLayout title="corb.cc">
  {floatingBits.map((bit) => (
    <span
      class="floating-bit"
      style={`
        top:${bit.top};
        left:${bit.left ?? "auto"};
        right:${bit.right ?? "auto"};
        color:${bit.color};
        font-size:${bit.size};
        transform: rotate(${bit.rotate});
      `}
      aria-hidden="true"
    >
      {bit.text}
    </span>
  ))}

  <section class="hero">
    <div class="hero-copy">
      <h1>
        a place
        <br />
        for
        <span class="accent-red pixel-all-wave" aria-label="all">
          <span>a</span><span>l</span><span>l</span>
        </span>
        <br />
        of my <span class="accent-blue">art</span>
      </h1>

      <p class="intro">
        art, photographs, films, restored objects, writings, experiments,
        illustrations and other stuff I want to keep online.
      </p>
    </div>

    <div class="hero-card">
      <div class="photo-wrap">
        <img
          src="/images/homepage_photo.jpg"
          alt="Featured image from corb.cc"
          class="homepage_photo"
        />
      </div>

      <p class="card-caption">self portrait - gameboy camera - 0.02 megapixels</p>
    </div>
  </section>

  <div class="rule"></div>

  <section class="content-grid">
    <article class="lead-story">
      <p class="section-label">currently</p>
      <h2>editing, restoring, thinking, climbing</h2>
      <p>
        This is the most awesome website of all time. It is meant to hold
        the parts of my life that usually end up scattered across too many
        places. Some of it is client work. Some of it is personal. Some of
        it is still unfinished. Idk hope you like it :)
      </p>
    </article>

    <aside class="menu-panel">
      <p class="section-label">index</p>
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href}>
              <span class="menu-word" style={`--menu-color:${item.color}`}>{item.label}</span>
              <span class="menu-meta">{item.meta}</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <div class="rule dashed"></div>

  <footer class="footer">
    <p>corb.cc — issue zero</p>
    <p>a collection of things I make and care about</p>
  </footer>
</BaseLayout>

<style>
  .floating-bit {
    position: absolute;
    line-height: 1;
    opacity: 0.72;
    user-select: none;
    pointer-events: none;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.95fr;
    gap: 2.2rem;
    align-items: center;
    padding: 2rem 0 1.6rem;
  }

  .hero-copy {
    padding-right: 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(4rem, 10vw, 8.5rem);
    line-height: 0.88;
    letter-spacing: -0.065em;
    font-weight: 500;
  }

  .accent-red {
    color: var(--red);
  }

  .accent-blue {
    color: var(--blue);
  }

  .intro {
    max-width: 34rem;
    margin: 1.25rem 0 0;
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .hero-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .photo-wrap {
    background: transparent;
    border: none;
    padding: 0;
  }

  .homepage_photo {
    display: block;
    width: 100%;
    height: 26rem;
    object-fit: cover;
    border: 1px solid rgba(36, 31, 27, 0.08);
    box-shadow: 0 12px 18px rgba(24, 20, 17, 0.05);
  }

  .card-caption {
    margin: 0.6rem 0 0;
    color: var(--soft);
    font-size: 0.88rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: start;
    padding: 1.4rem 0 1.8rem;
  }

  .lead-story h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 500;
  }

  .lead-story p:last-child {
    margin: 1rem 0 0;
    max-width: 36rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .menu-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .menu-panel a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.15rem 0;
    border-bottom: 1px solid rgba(36, 31, 27, 0.08);
    transition: transform 160ms ease;
  }

  .menu-panel a:hover {
    transform: translateX(0.3rem);
  }

  .menu-word {
    color: var(--menu-color);
    font-size: 1.5rem;
    line-height: 1;
    text-transform: lowercase;
  }

  .menu-meta {
    color: var(--muted);
    font-size: 0.92rem;
    text-align: right;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    color: var(--soft);
    font-size: 0.9rem;
  }

  .footer p {
    margin: 0;
  }

  @media (max-width: 980px) {
    .hero,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding-right: 0;
    }

    .homepage_photo {
      height: 22rem;
    }

    .footer {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .hero {
      gap: 1.4rem;
      padding: 1.5rem 0 1.25rem;
    }

    h1 {
      font-size: clamp(3rem, 14vw, 4.6rem);
      line-height: 0.92;
    }

    .intro {
      font-size: 1rem;
      line-height: 1.65;
      margin-top: 1rem;
    }

    .homepage_photo {
      height: auto;
    }

    .card-caption {
      margin-top: 0.5rem;
      font-size: 0.84rem;
    }

    .content-grid {
      gap: 1.5rem;
      padding: 1.2rem 0 1.5rem;
    }

    .lead-story h2 {
      font-size: clamp(2rem, 10vw, 3rem);
      line-height: 0.98;
    }

    .lead-story p:last-child {
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .menu-panel ul {
      gap: 0.7rem;
    }

    .menu-panel a {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
      padding: 0.25rem 0;
    }

    .menu-word {
      font-size: 1.2rem;
    }

    .menu-meta {
      font-size: 0.88rem;
      line-height: 1.45;
      text-align: left;
    }

    .footer {
      gap: 0.4rem;
      font-size: 0.82rem;
    }

    .floating-bit {
      opacity: 0.25;
    }
  }
</style>