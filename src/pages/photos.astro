---
import BaseLayout from "../layouts/BaseLayout.astro";

const photoSets = [
  {
    title: "Wedding Work",
    type: "weddings",
    description: "weddings, engagements, and client work",
    year: "selected work",
    tag: "client",
    color: "var(--red)",
    image: "/images/photos/wedding-work.jpg",
    href: "/photos/engagements"
  },
  {
    title: "Portraits",
    type: "portraits",
    description: "people, friends, and quieter images",
    year: "ongoing",
    tag: "people",
    color: "var(--blue)",
    image: "/images/photos/portraits.jpg",
    href: "https://youtube.com/"
  },
  {
    title: "Travel / Places",
    type: "travel",
    description: "images from places I’ve been and things I wanted to keep",
    year: "archive",
    tag: "places",
    color: "var(--green)",
    image: "/images/photos/travel-places.jpg",
    href: "https://youtube.com/"
  },
  {
    title: "Climbing",
    type: "climbing",
    description: "movement, texture, effort, and the spaces around it",
    year: "ongoing",
    tag: "motion",
    color: "var(--lavender)",
    image: "/images/photos/climbing.jpg",
    href: "/photos/climbing"
  }
];
---

<BaseLayout title="photos — corb.cc">
  <section class="page-intro">
    <div>
      <p class="eyebrow">photos</p>
      <h1>people, places, weddings, and everything else</h1>
      <p class="intro">
        Probably the deepest part of my work. Client work, personal images,
        travel, climbing, portraits, and other photos I want to keep close.
      </p>
    </div>

    <div class="side-note">
      <p>weddings</p>
      <p>engagements</p>
      <p>portraits</p>
      <p>travel</p>
    </div>
  </section>

  <div class="rule dashed"></div>

  <section class="filter-row" aria-label="Photo categories">
    <span>weddings</span>
    <span>engagements</span>
    <span>portraits</span>
    <span>travel</span>
    <span>personal</span>
    <span>climbing</span>
  </section>

  <div class="rule"></div>

  <section class="photos-grid">
    {photoSets.map((set) => (
      <article class="photo-card">
        <a href={set.href} target="_blank" rel="noreferrer" class="photo-link">
          <div class="image-wrap">
            <img src={set.image} alt={set.title} class="set-image" />
            <span class="set-tag" style={`--tag-color:${set.color}`}>{set.tag}</span>
          </div>

          <div class="set-info">
            <div class="set-topline">
              <h2>{set.title}</h2>
              <span class="set-year">{set.year}</span>
            </div>

            <p class="set-type" style={`--type-color:${set.color}`}>{set.type}</p>
            <p class="set-description">{set.description}</p>
          </div>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6.4rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
    max-width: 12ch;
  }

  .intro {
    max-width: 40rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 1rem 0;
  }

  .filter-row span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28rem 0.7rem;
    border: 1px solid rgba(36, 31, 27, 0.1);
    background: #faf8f4;
    font-size: 0.85rem;
    text-transform: lowercase;
    color: var(--muted);
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.8rem 1.5rem;
    padding-top: 1.6rem;
  }

  .photo-card {
    min-width: 0;
  }

  .photo-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .image-wrap {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(36, 31, 27, 0.08);
    box-shadow: 0 12px 18px var(--shadow);
    background: #f5f2ec;
  }

  .set-image {
    display: block;
    width: 100%;
    height: 24rem;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .set-tag {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    padding: 0.24rem 0.6rem;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(36, 31, 27, 0.1);
    font-size: 0.78rem;
    text-transform: lowercase;
    color: var(--tag-color);
  }

  .set-info {
    padding-top: 0.85rem;
  }

  .set-topline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }

  .set-topline h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  .set-year {
    color: var(--soft);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .set-type {
    margin: 0.55rem 0 0;
    color: var(--type-color);
    font-size: 0.93rem;
    text-transform: lowercase;
  }

  .set-description {
    margin: 0.65rem 0 0;
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.98rem;
    max-width: 34rem;
  }

  .photo-link:hover .set-image {
    transform: scale(1.02);
  }

  .photo-link:hover .set-topline h2 {
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .page-intro,
    .photos-grid {
      grid-template-columns: 1fr;
    }

    .side-note {
      justify-self: start;
      text-align: left;
    }

    .set-image {
      height: 20rem;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .set-image {
      height: 16rem;
    }

    .set-topline {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>