---
import BaseLayout from "../layouts/BaseLayout.astro";

const archiveCards = [
  {
    href: "/under-construction",
    title: "currently",
    subtitle: "what's going on right now",
    description: "what i’m making, thinking about, or stuck on lately",
    color: "var(--red)",
    rotate: "-1.5deg",
    size: "large"
  },
  {
    href: "/under-construction",
    title: "watching",
    subtitle: "movies / shows / videos",
    description: "everything from films to weird youtube rabbit holes",
    color: "var(--blue)",
    rotate: "1deg",
    size: "medium"
  },
  {
    href: "/under-construction",
    title: "playing",
    subtitle: "games i’m in",
    description: "stuff i’m playing through, revisiting, or thinking about",
    color: "var(--green)",
    rotate: "-0.5deg",
    size: "medium"
  },
  {
    href: "/under-construction",
    title: "reading",
    subtitle: "books / essays / threads",
    description: "books, articles, and things i keep meaning to finish",
    color: "var(--lavender)",
    rotate: "1.2deg",
    size: "small"
  },
  {
    href: "/under-construction",
    title: "pokemon team",
    subtitle: "critical information",
    description: "for the people demanding to know the lineup",
    color: "var(--yellow)",
    rotate: "-1deg",
    size: "small"
  },
  {
    href: "/under-construction",
    title: "favorite videos",
    subtitle: "youtube / essays / saved forever",
    description: "videos i love, revisit, or keep recommending",
    color: "var(--brown)",
    rotate: "0.8deg",
    size: "medium"
  },
  {
    href: "/under-construction",
    title: "thinking about",
    subtitle: "ideas / obsessions / fragments",
    description: "things that keep floating around in my head",
    color: "var(--text)",
    rotate: "-1.2deg",
    size: "large"
  }
];
---

<BaseLayout title="archive — corb.cc">
  <section class="page-intro">
    <div>
      <p class="eyebrow">archive</p>
      <h1>a peek inside my brain</h1>
      <p class="intro">
        media i love, games i’m playing, things i’m thinking about, and
        whatever else ends up living here.
      </p>
    </div>

    <div class="side-note">
      <p>favorites</p>
      <p>obsessions</p>
      <p>media</p>
      <p>fragments</p>
    </div>
  </section>

  <div class="rule dashed"></div>

  <section class="archive-collage">
    {archiveCards.map((card) => (
      <a
        href={card.href}
        class={`archive-card ${card.size}`}
        style={`--card-color:${card.color}; --card-rotate:${card.rotate};`}
      >
        <div class="card-top">
          <span class="mini-tag">{card.subtitle}</span>
          <span class="arrow">↗</span>
        </div>

        <div class="card-body">
          <h2>{card.title}</h2>
          <p>{card.description}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6.2rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
    max-width: 10ch;
  }

  .intro {
    max-width: 38rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .archive-collage {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.2rem;
    padding-top: 1.6rem;
  }

  .archive-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 14rem;
    padding: 1rem;
    border: 1px solid rgba(36, 31, 27, 0.1);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.95), rgba(248,246,241,0.95));
    box-shadow: 0 12px 18px var(--shadow);
    transform: rotate(var(--card-rotate));
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
    color: inherit;
    text-decoration: none;
  }

  .archive-card.large {
    grid-column: span 6;
  }

  .archive-card.medium {
    grid-column: span 4;
  }

  .archive-card.small {
    grid-column: span 3;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .mini-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.22rem 0.55rem;
    font-size: 0.78rem;
    text-transform: lowercase;
    border: 1px solid rgba(36, 31, 27, 0.1);
    background: color-mix(in srgb, var(--card-color) 12%, white);
    color: var(--text);
  }

  .arrow {
    color: var(--card-color);
    font-size: 1.1rem;
  }

  .card-body h2 {
    margin: 1.8rem 0 0.55rem;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
    max-width: 12ch;
  }

  .card-body p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    max-width: 28ch;
  }

  .archive-card:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 16px 24px rgba(24, 20, 17, 0.11);
    border-color: rgba(36, 31, 27, 0.16);
  }

  .archive-card:hover .card-body h2 {
    color: var(--card-color);
  }

  @media (max-width: 1100px) {
    .archive-card.large,
    .archive-card.medium {
      grid-column: span 6;
    }

    .archive-card.small {
      grid-column: span 4;
    }
  }

  @media (max-width: 900px) {
    .page-intro {
      grid-template-columns: 1fr;
    }

    .side-note {
      justify-self: start;
      text-align: left;
    }

    .archive-card.large,
    .archive-card.medium,
    .archive-card.small {
      grid-column: span 12;
      transform: rotate(0deg);
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .archive-card {
      min-height: 11rem;
    }
  }
</style>