---
import BaseLayout from "../layouts/BaseLayout.astro";

const message = "this page isn’t ready yet.";
const sub = "i’ll come back to it.";
---

<BaseLayout title="under construction — corb.cc">
  <section class="center">
    <p class="label">under construction</p>

    <h1>{message}</h1>

    <p class="sub">{sub}</p>

    <a href="/archive" class="back">← back to archive</a>
  </section>

  <div class="floating">
    <span>🚧</span>
    <span>✦</span>
    <span>…</span>
  </div>
</BaseLayout>

<style>
  .center {
    text-align: center;
    padding: 4rem 1rem;
  }

  .label {
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--muted);
  }

  h1 {
    margin: 0.5rem 0;
    font-size: 2.8rem;
    letter-spacing: -0.04em;
  }

  .sub {
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .back {
    text-decoration: none;
    border-bottom: 1px solid var(--text);
    padding-bottom: 0.1rem;
    color: inherit;
  }

  .floating {
    pointer-events: none;
    display: flex;
    justify-content: space-between;
    padding: 2rem 0;
    font-size: 1.2rem;
    opacity: 0.4;
  }
</style>