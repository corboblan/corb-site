---
const message = "Oops! This page isn’t ready yet.";
const sub = "i’ll come back to it.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>under construction — corb.com</title>
  </head>

  <body>
    <div class="paper-noise"></div>

    <main class="page">
      <header class="masthead">
        <div class="masthead-left">
          <span class="tiny-box">◻</span>
          <span class="tiny-box">✦</span>
          <span class="tiny-note">under construction</span>
        </div>

        <div class="site-mark"><a href="/">corb.com</a></div>

        <div class="masthead-right">
          <a href="/">home</a>
        </div>
      </header>

      <div class="rule"></div>

      <section class="center">
        <p class="label">under construction</p>

        <h1>{message}</h1>

        <p class="sub">{sub}</p>

        <a href="/archive" class="back">← back to archive</a>
      </section>

      <div class="floating">
        <span>🚧</span>
        <span>✦</span>
        <span>…</span>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #ffffff;
    --text: #241f1b;
    --muted: #6f685f;
    --soft: #9a9187;
    --line: rgba(36, 31, 27, 0.16);
  }

  body {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    background: var(--bg);
    color: var(--text);
  }

  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem 1.25rem 2rem;
    position: relative;
  }

  .masthead {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .tiny-box {
    border: 1px solid var(--text);
    padding: 0.2rem 0.4rem;
    font-size: 0.8rem;
  }

  .tiny-note {
    margin-left: 0.5rem;
    font-style: italic;
    color: var(--muted);
  }

  .site-mark a {
    text-decoration: none;
    color: inherit;
    font-style: italic;
    font-size: 2rem;
  }

  .rule {
    border-top: 1px solid var(--line);
    margin: 1rem 0;
  }

  .center {
    text-align: center;
    padding: 4rem 1rem;
  }

  .label {
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--muted);
  }

  h1 {
    margin: 0.5rem 0;
    font-size: 2.8rem;
    letter-spacing: -0.04em;
  }

  .sub {
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .back {
    text-decoration: none;
    border-bottom: 1px solid var(--text);
    padding-bottom: 0.1rem;
  }

  .floating {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    justify-content: space-between;
    padding: 2rem;
    font-size: 1.2rem;
    opacity: 0.4;
  }
</style>