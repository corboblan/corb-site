---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Crash Out",
    type: "short film",
    description: "An awarding-winning short film about pursuing the things that bring you joy, especially through heartbreak.",
    year: "2025",
    tag: "favorite",
    color: "var(--blue)",
    href: "https://youtu.be/C26oBHtdNnM",
    image: "/images/stuff/crash-out.jpg"
  },

  {
    title: "Game Boy Essay",
    type: "video essay",
    description: "a piece about returning to something simpler",
    year: "2025",
    tag: "video",
    color: "var(--red)",
    href: "https://youtube.com/YOUR_LINK_HERE",
    image: "/images/stuff/gameboy.jpg"
  },

  {
    title: "Untitled Experiment",
    type: "experiment",
    description: "still figuring this one out",
    year: "ongoing",
    tag: "in progress",
    color: "var(--green)",
    href: "/under-construction",
    image: "/images/stuff/placeholder.jpg"
  }
];
---

<BaseLayout title="stuff — corb.cc">
  <section class="page-intro">
    <div>
      <p class="eyebrow">stuff</p>
      <h1>projects</h1>
      <p class="intro">
        films, projects, and experiments. some finished, some still becoming.
      </p>
    </div>

    <div class="side-note">
      <p>film</p>
      <p>video</p>
      <p>experiments</p>
      <p>ideas</p>
    </div>
  </section>

  <div class="rule dashed"></div>

  <section class="projects">
    {projects.map((project) => (
      <a
        href={project.href}
        class="project-link"
        target={project.href.startsWith("http") ? "_blank" : undefined}
        rel={project.href.startsWith("http") ? "noreferrer" : undefined}
      >
        <div class="project">
          <div class="project-thumb">
            <img src={project.image} alt={project.title} />
            <span class="thumb-label">{project.tag}</span>
          </div>

          <div class="project-info">
            <div class="project-top">
              <h2 style={`color:${project.color}`}>{project.title}</h2>
              <span class="year">{project.year}</span>
            </div>

            <p class="type">{project.type}</p>
            <p class="description">{project.description}</p>
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
  }

  .intro {
    max-width: 38rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .projects {
    display: grid;
    gap: 2.2rem;
    padding: 1.6rem 0;
  }

  .project-link {
    text-decoration: none;
    color: inherit;
  }

  .project {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2rem;
    align-items: center;
  }

  /* 🔥 FIXED THUMBNAIL SYSTEM */
  .project-thumb {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(36, 31, 27, 0.08);
    background: #f5f2ec;
    box-shadow: 0 12px 18px var(--shadow);
    aspect-ratio: 4 / 5;
  }

  .project-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .project-link:hover .project-thumb img {
    transform: scale(1.03);
  }

  .thumb-label {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    padding: 0.22rem 0.55rem;
    font-size: 0.78rem;
    text-transform: lowercase;
    border: 1px solid rgba(36, 31, 27, 0.12);
    background: rgba(255, 255, 255, 0.9);
    z-index: 2;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  h2 {
    margin: 0;
    font-size: 1.8rem;
    letter-spacing: -0.02em;
  }

  .year {
    font-size: 0.9rem;
    color: var(--soft);
  }

  .type {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .description {
    margin: 0.4rem 0 0;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .page-intro {
      grid-template-columns: 1fr;
    }

    .side-note {
      justify-self: start;
      text-align: left;
    }

    .project {
      grid-template-columns: 1fr;
    }
  }
</style>