---
import BaseLayout from "../../layouts/BaseLayout.astro";

const images = import.meta.glob(
  "/public/images/photos/engagements/*.{jpg,jpeg,png,webp}",
  {
    eager: true,
    query: "?url",
    import: "default"
  }
);

const engagementPhotos = Object.values(images);
---

<BaseLayout title="engagements — corb.cc">
  <section class="page-intro">
    <div>
      <p class="eyebrow">photos / engagements</p>
      <h1>engagements</h1>
      <p class="intro">
        Movement, texture, effort, and the quiet space around all of it.
        A curated selection of engagements photographs.
      </p>
    </div>

    <div class="side-note">
      <p>movement</p>
      <p>chalk</p>
      <p>texture</p>
      <p>pause</p>
    </div>
  </section>

  <div class="rule dashed"></div>

  <section class="hero-image-section">
    <img
      src={engagementsPhotos[0]}
      alt="Featured engagements photograph"
      class="hero-image"
    />
  </section>

  <div class="rule"></div>

  <section class="gallery-intro">
    <p class="section-label">selected images</p>
    <p>
      Not sorted by trip. Just the images that feel strongest together.
    </p>
  </section>

  <section class="gallery-grid">
    {engagementsPhotos.slice(1).map((photo, index) => (
      <figure class={`gallery-item ${index % 5 === 0 ? "wide" : ""}`}>
        <img
          src={photo}
          alt={`engagements photograph ${index + 2}`}
          loading="lazy"
        />
      </figure>
    ))}
  </section>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
  }

  .intro {
    max-width: 38rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .hero-image-section {
    padding: 1.5rem 0;
  }

  .hero-image {
    display: block;
    width: 100%;
    max-height: 46rem;
    object-fit: cover;
    border: 1px solid rgba(36, 31, 27, 0.08);
    box-shadow: 0 12px 18px var(--shadow);
  }

  .gallery-intro {
    padding: 1.2rem 0 0.4rem;
  }

  .gallery-intro p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    max-width: 34rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
    padding: 1.2rem 0 2rem;
  }

  .gallery-item {
    grid-column: span 4;
    margin: 0;
  }

  .gallery-item.wide {
    grid-column: span 8;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 34rem;
    object-fit: cover;
    border: 1px solid rgba(36, 31, 27, 0.08);
    box-shadow: 0 10px 16px rgba(24, 20, 17, 0.05);
    background: #f5f2ec;
  }

  @media (max-width: 900px) {
    .page-intro {
      grid-template-columns: 1fr;
    }

    .side-note {
      justify-self: start;
      text-align: left;
    }

    .gallery-item,
    .gallery-item.wide {
      grid-column: span 12;
    }

    .hero-image {
      max-height: 30rem;
    }

    .gallery-item img {
      max-height: none;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .gallery-grid {
      gap: 0.8rem;
    }

    .hero-image {
      max-height: 22rem;
    }
  }
</style>