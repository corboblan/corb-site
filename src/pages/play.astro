---
import BaseLayout from "../layouts/BaseLayout.astro";

const topParts = [
  "/images/flipbook/face1_01.jpg",
  "/images/flipbook/face2_01.jpg",
  "/images/flipbook/face3_01.jpg",
  "/images/flipbook/face4_01.jpg",
  "/images/flipbook/face5_01.jpg",
  "/images/flipbook/face6_01.jpg",
  "/images/flipbook/face7_01.jpg",
  "/images/flipbook/face8_01.jpg"
];

const middleParts = [
  "/images/flipbook/face1_02.jpg",
  "/images/flipbook/face2_02.jpg",
  "/images/flipbook/face3_02.jpg",
  "/images/flipbook/face4_02.jpg",
  "/images/flipbook/face5_02.jpg",
  "/images/flipbook/face6_02.jpg",
  "/images/flipbook/face7_02.jpg",
  "/images/flipbook/face8_02.jpg"
];

const bottomParts = [
  "/images/flipbook/face1_03.jpg",
  "/images/flipbook/face2_03.jpg",
  "/images/flipbook/face3_03.jpg",
  "/images/flipbook/face4_03.jpg",
  "/images/flipbook/face5_03.jpg",
  "/images/flipbook/face6_03.jpg",
  "/images/flipbook/face7_03.jpg",
  "/images/flipbook/face8_03.jpg"
];
---

<BaseLayout title="play — corb.cc">
  <section class="page-intro">
    <div>
      <p class="eyebrow">play</p>
      <h1>build-a-corb</h1>
      <p class="intro">
        a little mix-and-match flipbook thing. it doesn’t really need to do
        anything. i guess that’s part of the point. i hope you enjoying building a corb
      </p>
    </div>

    <div class="side-note">
      <p>top / middle / bottom</p>
      <p>mix things up</p>
      <p>make something weird</p>
    </div>
  </section>

  <div class="rule dashed"></div>

  <section class="flipbook-section">
    <div class="flipbook-wrap">
      <div class="flip-stage">
        <div class="flip-stack">
          <div class="slice slice-top">
            <button
              type="button"
              class="slice-arrow left"
              data-target="top"
              data-direction="-1"
              aria-label="Previous top section"
            >
              ←
            </button>

            <div class="slice-image-wrap">
              <img
                id="slice-top-image"
                src={topParts[0]}
                alt="Top section of the flipbook face"
              />
            </div>

            <button
              type="button"
              class="slice-arrow right"
              data-target="top"
              data-direction="1"
              aria-label="Next top section"
            >
              →
            </button>
          </div>

          <div class="slice slice-middle">
            <button
              type="button"
              class="slice-arrow left"
              data-target="middle"
              data-direction="-1"
              aria-label="Previous middle section"
            >
              ←
            </button>

            <div class="slice-image-wrap">
              <img
                id="slice-middle-image"
                src={middleParts[0]}
                alt="Middle section of the flipbook face"
              />
            </div>

            <button
              type="button"
              class="slice-arrow right"
              data-target="middle"
              data-direction="1"
              aria-label="Next middle section"
            >
              →
            </button>
          </div>

          <div class="slice slice-bottom">
            <button
              type="button"
              class="slice-arrow left"
              data-target="bottom"
              data-direction="-1"
              aria-label="Previous bottom section"
            >
              ←
            </button>

            <div class="slice-image-wrap">
              <img
                id="slice-bottom-image"
                src={bottomParts[0]}
                alt="Bottom section of the flipbook face"
              />
            </div>

            <button
              type="button"
              class="slice-arrow right"
              data-target="bottom"
              data-direction="1"
              aria-label="Next bottom section"
            >
              →
            </button>
          </div>
        </div>
      </div>
    </div>

    <aside class="play-note">
      <p class="section-label">note</p>
      <p>
        Eight faces, split into thirds. Shuffle them around and make
        something cursed or beautiful.
      </p>

      <button type="button" id="randomize-button" class="randomize-button">
        randomize everything
      </button>
    </aside>
  </section>

  <div class="rule"></div>

  <section class="more-soon">
    <p class="section-label">eventually</p>
    <p>
      sound player / draggable collage / weird desktop / little game /
      hidden pages
    </p>
  </section>

  <script define:vars={{ topParts, middleParts, bottomParts }}>
    const state = {
      top: 0,
      middle: 0,
      bottom: 0
    };

    const collections = {
      top: topParts,
      middle: middleParts,
      bottom: bottomParts
    };

    const images = {
      top: document.getElementById("slice-top-image"),
      middle: document.getElementById("slice-middle-image"),
      bottom: document.getElementById("slice-bottom-image")
    };

    function wrapIndex(index, length) {
      return (index + length) % length;
    }

    function updatePart(part, nextIndex) {
      const image = images[part];
      const items = collections[part];
      state[part] = wrapIndex(nextIndex, items.length);

      image.classList.remove("is-visible");
      image.classList.add("is-hidden");

      window.setTimeout(() => {
        image.src = items[state[part]];
        image.classList.remove("is-hidden");
        image.classList.add("is-visible");
      }, 120);
    }

    document.querySelectorAll("[data-target]").forEach((button) => {
      button.addEventListener("click", () => {
        const part = button.dataset.target;
        const direction = Number(button.dataset.direction);
        updatePart(part, state[part] + direction);
      });
    });

    const randomizeButton = document.getElementById("randomize-button");
    randomizeButton?.addEventListener("click", () => {
      Object.keys(collections).forEach((part) => {
        const items = collections[part];
        const randomIndex = Math.floor(Math.random() * items.length);
        updatePart(part, randomIndex);
      });
    });

    Object.values(images).forEach((image) => {
      image.classList.add("is-visible");
    });
  </script>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
    max-width: 10ch;
  }

  .intro {
    max-width: 38rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .flipbook-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0;
    align-items: start;
  }

  .flipbook-wrap {
    display: grid;
    gap: 1rem;
  }

  .randomize-button {
    appearance: none;
    border: 1px solid rgba(36, 31, 27, 0.16);
    background: #faf8f4;
    color: var(--text);
    padding: 0.55rem 0.8rem;
    font: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    transition:
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .randomize-button:hover {
    transform: translateY(-1px);
    background: white;
    border-color: rgba(36, 31, 27, 0.28);
  }

  .flip-stage {
    background: #f7f3ec;
    border: 1px solid rgba(36, 31, 27, 0.1);
    padding: 1.8rem 3.4rem;
    box-shadow: 0 14px 22px var(--shadow);
  }

  .flip-stack {
    width: min(100%, 30rem);
    margin: 0 auto;
    display: grid;
    gap: 0;
  }

  .slice {
    position: relative;
    overflow: visible;
    background: transparent;
  }

  .slice-image-wrap {
    overflow: hidden;
    border-left: 1px solid rgba(36, 31, 27, 0.08);
    border-right: 1px solid rgba(36, 31, 27, 0.08);
    border-top: 1px solid rgba(36, 31, 27, 0.08);
    background: white;
  }

  .slice-bottom .slice-image-wrap {
    border-bottom: 1px solid rgba(36, 31, 27, 0.08);
  }

  .slice img {
    display: block;
    width: 100%;
    height: auto;
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      filter 140ms ease;
  }

  .slice img.is-hidden {
    opacity: 0;
    transform: translateY(8px);
    filter: blur(1px);
  }

  .slice img.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .slice-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid rgba(36, 31, 27, 0.14);
    background: rgba(250, 248, 244, 0.95);
    color: var(--text);
    font: inherit;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      opacity 160ms ease;
    opacity: 0.9;
  }

  .slice-arrow.left {
    left: -3rem;
  }

  .slice-arrow.right {
    right: -3rem;
  }

  .slice-arrow:hover {
    background: white;
    border-color: rgba(36, 31, 27, 0.28);
    opacity: 1;
  }

  .play-note {
    padding-top: 0.2rem;
  }

  .play-note p:last-of-type,
  .more-soon p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    max-width: 30rem;
  }

  .randomize-button {
    margin-top: 1rem;
  }

  .more-soon {
    padding-top: 1.2rem;
  }

  @media (max-width: 900px) {
    .page-intro,
    .flipbook-section {
      grid-template-columns: 1fr;
    }

    .side-note {
      justify-self: start;
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .flip-stage {
      padding: 1rem 2.4rem;
    }

    .slice-arrow {
      width: 2rem;
      height: 2rem;
      font-size: 1rem;
    }

    .slice-arrow.left {
      left: -2.2rem;
    }

    .slice-arrow.right {
      right: -2.2rem;
    }
  }
</style>