---
const topNavItems = [
  { href: "/stuff", label: "stuff" },
  { href: "/photos", label: "photos" },
  { href: "/things", label: "things" },
  { href: "/fine-arts", label: "fine arts" },
  { href: "/writing", label: "writing" },
  { href: "/archive", label: "archive" },
  { href: "/play", label: "play" }
];

const topParts = [
  "/images/flipbook/top-1.png",
  "/images/flipbook/top-2.png",
  "/images/flipbook/top-3.png"
];

const middleParts = [
  "/images/flipbook/middle-1.png",
  "/images/flipbook/middle-2.png",
  "/images/flipbook/middle-3.png"
];

const bottomParts = [
  "/images/flipbook/bottom-1.png",
  "/images/flipbook/bottom-2.png",
  "/images/flipbook/bottom-3.png"
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>play — corb.cc</title>
    <meta
      name="description"
      content="Experiments, interactions, and playful things on corb.cc."
    />
  </head>

  <body>
    <div class="paper-noise"></div>

    <main class="page">
      <header class="masthead">
        <div class="masthead-left">
          <span class="tiny-box">◻</span>
          <span class="tiny-box">✦</span>
          <span class="tiny-note">play / experiments / unnecessary things</span>
        </div>

        <div class="site-mark"><a href="/">corb.cc</a></div>

        <div class="masthead-right">
          <a href="/">home</a>
        </div>
      </header>

      <div class="rule"></div>

      <section class="top-strip">
        <p class="stamp">issue 00 / play page</p>

        <nav class="top-nav" aria-label="Primary">
          {topNavItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <p class="stamp right">keep wandering</p>
      </section>

      <div class="rule dashed"></div>

      <section class="page-intro">
        <div>
          <p class="eyebrow">play</p>
          <h1>exquisite corpse</h1>
          <p class="intro">
            A little mix-and-match flipbook thing. It doesn’t really need to do
            anything. That’s part of the point.
          </p>
        </div>

        <div class="side-note">
          <p>top / middle / bottom</p>
          <p>mix things up</p>
          <p>make something weird</p>
        </div>
      </section>

      <div class="rule dashed"></div>

      <section class="flipbook-section">
        <div class="flipbook-wrap">
          <div class="flip-controls">
            <button type="button" class="part-button" data-target="top" data-direction="-1">← top</button>
            <button type="button" class="part-button" data-target="top" data-direction="1">top →</button>
          </div>

          <div class="flip-stage">
            <div class="flip-stack">
              <div class="slice slice-top">
                <img id="slice-top-image" src={topParts[0]} alt="Top section of the flipbook figure" />
              </div>

              <div class="slice slice-middle">
                <img id="slice-middle-image" src={middleParts[0]} alt="Middle section of the flipbook figure" />
              </div>

              <div class="slice slice-bottom">
                <img id="slice-bottom-image" src={bottomParts[0]} alt="Bottom section of the flipbook figure" />
              </div>
            </div>
          </div>

          <div class="flip-controls">
            <button type="button" class="part-button" data-target="middle" data-direction="-1">← middle</button>
            <button type="button" class="part-button" data-target="middle" data-direction="1">middle →</button>
          </div>

          <div class="flip-controls">
            <button type="button" class="part-button" data-target="bottom" data-direction="-1">← bottom</button>
            <button type="button" class="part-button" data-target="bottom" data-direction="1">bottom →</button>
          </div>
        </div>

        <aside class="play-note">
          <p class="section-label">note</p>
          <p>
            Later you can make this creepier, funnier, more hand-drawn, or more
            collage-like. Right now this is the machine.
          </p>

          <button type="button" id="randomize-button" class="randomize-button">
            randomize everything
          </button>
        </aside>
      </section>

      <div class="rule"></div>

      <section class="more-soon">
        <p class="section-label">eventually</p>
        <p>
          sound player / draggable collage / weird desktop / little game /
          hidden pages
        </p>
      </section>
    </main>

    <script define:vars={{ topParts, middleParts, bottomParts }}>
      const state = {
        top: 0,
        middle: 0,
        bottom: 0
      };

      const collections = {
        top: topParts,
        middle: middleParts,
        bottom: bottomParts
      };

      const images = {
        top: document.getElementById("slice-top-image"),
        middle: document.getElementById("slice-middle-image"),
        bottom: document.getElementById("slice-bottom-image")
      };

      function wrapIndex(index, length) {
        return (index + length) % length;
      }

      function updatePart(part, nextIndex) {
        const image = images[part];
        const items = collections[part];
        state[part] = wrapIndex(nextIndex, items.length);

        image.classList.remove("is-visible");
        image.classList.add("is-hidden");

        window.setTimeout(() => {
          image.src = items[state[part]];
          image.classList.remove("is-hidden");
          image.classList.add("is-visible");
        }, 120);
      }

      document.querySelectorAll(".part-button").forEach((button) => {
        button.addEventListener("click", () => {
          const part = button.dataset.target;
          const direction = Number(button.dataset.direction);
          updatePart(part, state[part] + direction);
        });
      });

      const randomizeButton = document.getElementById("randomize-button");
      randomizeButton?.addEventListener("click", () => {
        Object.keys(collections).forEach((part) => {
          const items = collections[part];
          const randomIndex = Math.floor(Math.random() * items.length);
          updatePart(part, randomIndex);
        });
      });

      Object.values(images).forEach((image) => {
        image.classList.add("is-visible");
      });
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #ffffff;
    --text: #241f1b;
    --muted: #6f685f;
    --soft: #9a9187;
    --line: rgba(36, 31, 27, 0.16);

    --red: #d94c37;
    --blue: #2456a6;
    --green: #4d765d;
    --lavender: #c1b8ea;
    --brown: #7a4333;
    --yellow: #dec95d;

    --shadow: rgba(24, 20, 17, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100%;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: Georgia, "Times New Roman", Times, serif;
    overflow-x: hidden;
  }

  .paper-noise {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.05;
    background-image:
      radial-gradient(circle at 20% 15%, rgba(0, 0, 0, 0.05), transparent 24%),
      radial-gradient(circle at 78% 22%, rgba(0, 0, 0, 0.03), transparent 20%),
      radial-gradient(circle at 35% 82%, rgba(0, 0, 0, 0.03), transparent 20%);
    mix-blend-mode: multiply;
  }

  .page {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1rem 1.25rem 2.5rem;
  }

  .masthead {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.35rem 0 0.75rem;
  }

  .masthead-left,
  .masthead-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .masthead-right {
    justify-content: flex-end;
  }

  .tiny-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border: 1px solid var(--text);
    font-size: 0.78rem;
    background: white;
  }

  .tiny-note {
    font-size: 0.95rem;
    color: var(--muted);
    font-style: italic;
  }

  .site-mark {
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1;
    font-style: italic;
    letter-spacing: -0.03em;
  }

  .site-mark a,
  .masthead-right a,
  .top-nav a {
    color: inherit;
    text-decoration: none;
  }

  .masthead-right a {
    border: 1px solid var(--text);
    border-radius: 999px;
    padding: 0.22rem 0.8rem;
    font-size: 0.92rem;
    background: white;
    transition: background 160ms ease, color 160ms ease;
  }

  .masthead-right a:hover {
    background: var(--text);
    color: white;
  }

  .rule {
    border-top: 1px solid var(--line);
  }

  .rule.dashed {
    border-top-style: dashed;
  }

  .top-strip {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 0.7rem 0;
  }

  .stamp {
    margin: 0;
    font-size: 0.84rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .stamp.right {
    text-align: right;
  }

  .top-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.15rem;
  }

  .top-nav a {
    font-size: 0.95rem;
    color: var(--muted);
    transition: color 160ms ease, transform 160ms ease;
    text-transform: lowercase;
  }

  .top-nav a:hover {
    color: var(--text);
    transform: translateY(-1px);
  }

  .page-intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0 1.4rem;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: lowercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 500;
    max-width: 10ch;
  }

  .intro {
    max-width: 38rem;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .side-note {
    justify-self: end;
    text-align: right;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .side-note p {
    margin: 0;
  }

  .flipbook-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    padding: 1.8rem 0;
    align-items: start;
  }

  .flipbook-wrap {
    display: grid;
    gap: 1rem;
  }

  .flip-controls {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .part-button,
  .randomize-button {
    appearance: none;
    border: 1px solid rgba(36, 31, 27, 0.16);
    background: #faf8f4;
    color: var(--text);
    padding: 0.55rem 0.8rem;
    font: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    transition:
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .part-button:hover,
  .randomize-button:hover {
    transform: translateY(-1px);
    background: white;
    border-color: rgba(36, 31, 27, 0.28);
  }

  .flip-stage {
    background: #f7f3ec;
    border: 1px solid rgba(36, 31, 27, 0.1);
    padding: 1rem;
    box-shadow: 0 14px 22px var(--shadow);
  }

  .flip-stack {
    width: min(100%, 30rem);
    margin: 0 auto;
    display: grid;
    gap: 0;
  }

  .slice {
    position: relative;
    overflow: hidden;
    border-left: 1px solid rgba(36, 31, 27, 0.08);
    border-right: 1px solid rgba(36, 31, 27, 0.08);
    border-top: 1px solid rgba(36, 31, 27, 0.08);
    background: white;
  }

  .slice-bottom {
    border-bottom: 1px solid rgba(36, 31, 27, 0.08);
  }

  .slice img {
    display: block;
    width: 100%;
    height: auto;
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      filter 140ms ease;
  }

  .slice img.is-hidden {
    opacity: 0;
    transform: translateY(8px);
    filter: blur(1px);
  }

  .slice img.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .play-note {
    padding-top: 0.2rem;
  }

  .section-label {
    margin: 0 0 0.7rem;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .play-note p:last-of-type,
  .more-soon p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    max-width: 30rem;
  }

  .randomize-button {
    margin-top: 1rem;
  }

  .more-soon {
    padding-top: 1.2rem;
  }

  @media (max-width: 1100px) {
    .top-nav {
      justify-content: flex-start;
    }

    .top-strip {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .stamp.right {
      text-align: left;
    }
  }

  @media (max-width: 900px) {
    .masthead,
    .page-intro,
    .flipbook-section {
      grid-template-columns: 1fr;
    }

    .masthead-right,
    .site-mark,
    .side-note {
      justify-content: flex-start;
      text-align: left;
    }

    .side-note {
      justify-self: start;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 0.8rem 0.9rem 1.8rem;
    }

    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .flip-stage {
      padding: 0.75rem;
    }
  }
</style>